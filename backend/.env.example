# PrepIQ Backend Configuration Example

# Django Settings
DEBUG=True
SECRET_KEY=django-insecure-change-this-in-production-123456
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# OpenRouter Settings
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_FALLBACK_MODEL=google/gemma-2-9b-it:free

# Database Configuration (Optional, defaults to SQLite if not provided)
# DATABASE_URL=postgres://user:password@localhost:5432/prepiq

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Security
# DJANGO_DEV_MODE: Set to true ONLY for local development to allow falling back to dev-only keys.
# WARNING: This MUST be unset or set to false in any deployed/production environment.
# Never copy this variable into a hosting provider's environment variable dashboard (Render/Railway/Vercel/etc.).
DJANGO_DEV_MODE=false
RESUME_ENCRYPTION_KEY=generate-a-32-byte-base64-key-using-cryptography-fernet
